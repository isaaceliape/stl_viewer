{
  "name": "stl-viewer",
  "version": "1.0.0",
  "description": "Advanced STL/3MF Gallery Viewer for 3D Models",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"BROWSER=none PORT=3010 react-scripts start\" \"wait-on http://localhost:3010 && electron .\"",
    "build": "react-scripts build",
    "build-app": "npm run build && electron-builder",
    "start": "electron .",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "dev-win": "concurrently \"set BROWSER=none && set PORT=3010 && react-scripts start\" \"wait-on http://localhost:3010 && electron .\""
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "three": "^0.148.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.6.4",
    "electron-reload": "^2.0.0-alpha.1",
    "concurrently": "^8.2.1",
    "wait-on": "^7.0.1",
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.148.0",
    "@types/node": "^20.10.0",
    "@types/jszip": "^3.4.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.stlviewer.app",
    "productName": "STL Viewer",
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/preload.js",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}